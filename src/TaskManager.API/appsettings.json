{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  "AllowedHosts": "*",
  "CosmosDb": {
    "EndpointUri": "",
    "PrimaryKey": "",
    "DatabaseName": "TaskManagerSaaS"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "TaskManagerSaaS",
    "Audience": "TaskManagerUsers",
    "AccessTokenExpiryMinutes": "15"
  },
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "dharmilhalpatics12@gmail.com"
  }
}